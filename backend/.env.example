# AI Architecture Visualization - Environment Configuration

# AI Image Generation Providers
# 通义万相 (推荐国内使用)
QIANWEN_API_KEY=your_qianwen_api_key_here

# Midjourney (通过第三方 API)
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=your_stability_api_key_here

# 3D Reconstruction
# Luma AI (云端快速重建)
LUMA_API_KEY=your_luma_api_key_here

# OpenAI (用于材质分析)
OPENAI_API_KEY=your_openai_api_key_here

# 默认使用的 AI 提供商
AI_PROVIDER=qianwen

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 文件存储
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
